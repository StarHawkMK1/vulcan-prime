ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
VAULT_PATH=D:/python-workspace/vulcan-prime/vault

# ── Metering ──────────────────────────────────────────────
# Token limits per tool (0 = unknown, hides progress bar)
CC_5H_LIMIT=500000
CC_WEEKLY_LIMIT=5000000
CODEX_5H_LIMIT=500000
CODEX_WEEKLY_LIMIT=5000000
AG_5H_LIMIT=0
AG_WEEKLY_LIMIT=0

# Antigravity Language Server (leave port 0 to disable)
AG_LS_PORT=9000

# Scanner
METERING_SCAN_INTERVAL=300
METERING_DB_PATH=.metering.db
